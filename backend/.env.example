SECRET_KEY=REPLACE_THIS_WITH_A_REAL_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./pathology.db
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
